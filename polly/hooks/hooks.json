{
  "description": "Retrieve scoped Polly context and maintain rolling private checkpoints.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$PLUGIN_ROOT/scripts/polly_bridge.py\" hook",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\scripts\\polly_bridge.py\" hook",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$PLUGIN_ROOT/scripts/polly_bridge.py\" hook",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\scripts\\polly_bridge.py\" hook",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$PLUGIN_ROOT/scripts/polly_bridge.py\" hook",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\scripts\\polly_bridge.py\" hook",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
