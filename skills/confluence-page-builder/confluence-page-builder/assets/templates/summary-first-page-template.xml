<h2>Legend And FAQ</h2>
<h3><span style="color:#312D2A;">Legend</span></h3>
<ac:structured-macro ac:macro-id="{{slug}}-legend-tabs" ac:name="ui-tabs" ac:schema-version="1">
  <ac:rich-text-body>
    <ac:structured-macro ac:macro-id="{{slug}}-legend-tab-process" ac:name="ui-tab" ac:schema-version="1">
      <ac:parameter ac:name="title">Process Terms</ac:parameter>
      <ac:rich-text-body>
        <table class="wrapped">
          <tbody>
            <tr>
              <th>Term</th>
              <th>Meaning</th>
              <th>Where It Shows Up</th>
            </tr>
            <tr>
              <td>{{legend_term_one}}</td>
              <td>{{legend_term_one_meaning}}</td>
              <td>{{legend_term_one_location}}</td>
            </tr>
            <tr>
              <td>{{legend_term_two}}</td>
              <td>{{legend_term_two_meaning}}</td>
              <td>{{legend_term_two_location}}</td>
            </tr>
            <tr>
              <td>{{legend_term_three}}</td>
              <td>{{legend_term_three_meaning}}</td>
              <td>{{legend_term_three_location}}</td>
            </tr>
          </tbody>
        </table>
      </ac:rich-text-body>
    </ac:structured-macro>
    <ac:structured-macro ac:macro-id="{{slug}}-legend-tab-status" ac:name="ui-tab" ac:schema-version="1">
      <ac:parameter ac:name="title">Status Labels</ac:parameter>
      <ac:rich-text-body>
        <table class="wrapped">
          <tbody>
            <tr>
              <th>Status</th>
              <th>Color</th>
              <th>Meaning</th>
              <th>Use When</th>
            </tr>
            <tr>
              <td>
                <ac:structured-macro ac:macro-id="{{slug}}-status-current" ac:name="status" ac:schema-version="1">
                  <ac:parameter ac:name="colour">Green</ac:parameter>
                  <ac:parameter ac:name="title">CURRENT</ac:parameter>
                </ac:structured-macro>
              </td>
              <td><span style="color:#5F7D4F;"><strong>Green</strong></span></td>
              <td>{{status_current_meaning}}</td>
              <td>{{status_current_use}}</td>
            </tr>
            <tr>
              <td>
                <ac:structured-macro ac:macro-id="{{slug}}-status-pending" ac:name="status" ac:schema-version="1">
                  <ac:parameter ac:name="colour">Yellow</ac:parameter>
                  <ac:parameter ac:name="title">PENDING</ac:parameter>
                </ac:structured-macro>
              </td>
              <td><span style="color:#AA643B;"><strong>Yellow</strong></span></td>
              <td>{{status_pending_meaning}}</td>
              <td>{{status_pending_use}}</td>
            </tr>
            <tr>
              <td>
                <ac:structured-macro ac:macro-id="{{slug}}-status-review" ac:name="status" ac:schema-version="1">
                  <ac:parameter ac:name="colour">Grey</ac:parameter>
                  <ac:parameter ac:name="title">REVIEW</ac:parameter>
                </ac:structured-macro>
              </td>
              <td><span style="color:#697778;"><strong>Grey</strong></span></td>
              <td>{{status_review_meaning}}</td>
              <td>{{status_review_use}}</td>
            </tr>
            <tr>
              <td>
                <ac:structured-macro ac:macro-id="{{slug}}-status-qa" ac:name="status" ac:schema-version="1">
                  <ac:parameter ac:name="colour">Blue</ac:parameter>
                  <ac:parameter ac:name="title">QA</ac:parameter>
                </ac:structured-macro>
              </td>
              <td><span style="color:#00688C;"><strong>Blue</strong></span></td>
              <td>{{status_qa_meaning}}</td>
              <td>{{status_qa_use}}</td>
            </tr>
            <tr>
              <td>
                <ac:structured-macro ac:macro-id="{{slug}}-status-flag" ac:name="status" ac:schema-version="1">
                  <ac:parameter ac:name="colour">Red</ac:parameter>
                  <ac:parameter ac:name="title">FLAG</ac:parameter>
                </ac:structured-macro>
              </td>
              <td><span style="color:#C74634;"><strong>Red</strong></span></td>
              <td>{{status_flag_meaning}}</td>
              <td>{{status_flag_use}}</td>
            </tr>
          </tbody>
        </table>
      </ac:rich-text-body>
    </ac:structured-macro>
    <ac:structured-macro ac:macro-id="{{slug}}-legend-tab-records" ac:name="ui-tab" ac:schema-version="1">
      <ac:parameter ac:name="title">Records &amp; Artifacts</ac:parameter>
      <ac:rich-text-body>
        <table class="wrapped">
          <tbody>
            <tr>
              <th>Record</th>
              <th>What It Tracks</th>
              <th>Owner Action</th>
            </tr>
            <tr>
              <td>{{record_one_name}}</td>
              <td>{{record_one_tracks}}</td>
              <td>{{record_one_action}}</td>
            </tr>
            <tr>
              <td>{{record_two_name}}</td>
              <td>{{record_two_tracks}}</td>
              <td>{{record_two_action}}</td>
            </tr>
            <tr>
              <td>{{record_three_name}}</td>
              <td>{{record_three_tracks}}</td>
              <td>{{record_three_action}}</td>
            </tr>
          </tbody>
        </table>
      </ac:rich-text-body>
    </ac:structured-macro>
  </ac:rich-text-body>
</ac:structured-macro>
