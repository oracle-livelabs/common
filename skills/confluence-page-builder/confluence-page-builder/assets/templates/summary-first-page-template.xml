<ac:structured-macro ac:macro-id="{{slug}}-top-band" ac:name="section" ac:schema-version="1">
  <ac:rich-text-body>
    <ac:structured-macro ac:macro-id="{{slug}}-mission-column" ac:name="column" ac:schema-version="1">
      <ac:parameter ac:name="width">34%</ac:parameter>
      <ac:rich-text-body>
        <ac:structured-macro ac:macro-id="{{slug}}-mission" ac:name="info" ac:schema-version="1">
          <ac:rich-text-body>
            <h2><span style="color:#C74634;"><strong>Mission</strong></span></h2>
            <p>{{mission}}</p>
            <p><strong>Outcome:</strong> {{outcome}}</p>
          </ac:rich-text-body>
        </ac:structured-macro>
      </ac:rich-text-body>
    </ac:structured-macro>
    <ac:structured-macro ac:macro-id="{{slug}}-team-column" ac:name="column" ac:schema-version="1">
      <ac:parameter ac:name="width">33%</ac:parameter>
      <ac:rich-text-body>
        <h2>Team &amp; Roles</h2>
        <ul>
          <li><p><strong>{{role_one_name}}</strong> - {{role_one_responsibility}}</p></li>
          <li><p><strong>{{role_two_name}}</strong> - {{role_two_responsibility}}</p></li>
          <li><p><strong>{{role_three_name}}</strong> - {{role_three_responsibility}}</p></li>
        </ul>
        <h2>Key Links</h2>
        <ul>
          <li><p><a href="{{link_one_url}}">{{link_one_label}}</a></p></li>
          <li><p><a href="{{link_two_url}}">{{link_two_label}}</a></p></li>
          <li><p><a href="{{link_three_url}}">{{link_three_label}}</a></p></li>
        </ul>
      </ac:rich-text-body>
    </ac:structured-macro>
    <ac:structured-macro ac:macro-id="{{slug}}-contents-column" ac:name="column" ac:schema-version="1">
      <ac:parameter ac:name="width">33%</ac:parameter>
      <ac:rich-text-body>
        <h2>Contents</h2>
        <ac:structured-macro ac:macro-id="{{slug}}-toc" ac:name="toc" ac:schema-version="1">
          <ac:parameter ac:name="maxLevel">3</ac:parameter>
        </ac:structured-macro>
      </ac:rich-text-body>
    </ac:structured-macro>
  </ac:rich-text-body>
</ac:structured-macro>

